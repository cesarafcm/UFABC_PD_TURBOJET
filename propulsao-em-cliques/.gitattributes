# Normalize line endings to LF on commit
* text=auto eol=lf

# Force LF for web files
*.js   eol=lf
*.jsx  eol=lf
*.ts   eol=lf
*.tsx  eol=lf
*.css  eol=lf
*.html eol=lf
*.json eol=lf
*.md   eol=lf

# Binary files — no line ending conversion
*.png  binary
*.jpg  binary
*.svg  binary
*.ico  binary
*.woff binary
*.woff2 binary
